# Copy to .env.local and fill in at least one provider key.
# Keys here are server-side fallbacks for local dev. In the app you can also
# enter keys per-provider in the Settings drawer (stored in your browser only).

# --- Provider API keys (set at least one) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
FIREWORKS_API_KEY=

# --- Public deploy (bring-your-own-key only) ---
# When true, the server IGNORES the keys above and every visitor must supply
# their own key in Settings — so a public deploy never spends the owner's key.
# Leave unset/false for local dev. Set BOTH (the NEXT_PUBLIC_ one drives the UI banner).
# PUBLIC_BYO_KEY_ONLY=true
# NEXT_PUBLIC_BYO_KEY_ONLY=true

# --- iii engine backend (optional) ---
# The app can run agent turns on the iii engine instead of the in-app harness,
# selectable from the chat UI (per-run) and Settings (global default). These
# only matter when a run uses the `iii` backend; the in-app harness needs none.
# See README "Deploy the iii engine" for the Fly.io setup.
#
# App side (set on Vercel / wherever the Next app runs):
#   HTTP endpoint of the engine (the worker's POST /run trigger).
# III_ENGINE_HTTP_URL=https://mat-iii-engine.fly.dev
#   Shared secret authorizing a run (must match the engine's III_ENGINE_TOKEN).
# III_ENGINE_TOKEN=
#   Path the worker serves the run trigger on (default /run).
# III_RUN_PATH=/run
#   Per-turn timeout in ms (agent runs are long). Default 240000.
# III_TURN_TIMEOUT_MS=240000
#   Set true to drop the "preview" hint on the iii option once the engine is up.
# NEXT_PUBLIC_III_BACKEND_ENABLED=true
#
# Engine/worker side (set as Fly secrets, not here):
#   III_ENGINE_URL=ws://localhost:49134   # worker → engine bus (in-container)
#   III_ENGINE_TOKEN=...                   # same secret as the app side
#   MAT_RUN_FUNCTION_ID=mat::run           # optional override
#
# Prebuilt-worker adoption (all OFF by default; the batch path is the default).
# Turn each on once verified against your engine. App + worker flags marked.
#   III_STREAM_ENABLED=true   # app+worker: live events via iii-stream
#   III_STREAM_URL=           # app: engine Stream API base (default host:3112)
#   III_STREAM_READ_PATH=/streams/{stream}/{group}   # app: read path template
#   III_STREAM_PUBLISH_FN=stream::publish            # worker: publish fn id
#   III_STATE_ENABLED=true    # worker: server-side sessions via iii-state
#   III_STATE_GET_FN=state::get
#   III_STATE_SET_FN=state::set
#   III_STATE_SCOPE=mat:session
#   III_QUEUE_ENABLED=true    # worker: durable runs via iii-queue
#   III_QUEUE_NAME=mat
#   III_POLICY_ENABLED=true   # worker: gate tools via policy::check_permissions
#   III_POLICY_FN=policy::check_permissions          # reads iii-permissions.yaml

# --- Smoke test (optional) ---
# SMOKE_MODEL=gpt-5.4-mini
